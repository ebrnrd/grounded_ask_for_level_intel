    ["trader"]   = { paid_chance = 70, free_chance = 30, refuse_chance = 0 },
    ["bandit"]   = { paid_chance = 60, free_chance = 20, refuse_chance = 20 },
    ["stalker"]  = { paid_chance = 30, free_chance = 60, refuse_chance = 10 },
    ["army"]     = { paid_chance = 50, free_chance = 10, refuse_chance = 40 },
    ["dolg"]     = { paid_chance = 40, free_chance = 20, refuse_chance = 40 },
    ["freedom"]  = { paid_chance = 20, free_chance = 70, refuse_chance = 10 },
    ["csky"]     = { paid_chance = 40, free_chance = 50, refuse_chance = 10 },
    ["ecolog"]   = { paid_chance = 30, free_chance = 50, refuse_chance = 20 },
    ["killer"]   = { paid_chance = 75, free_chance = 10, refuse_chance = 15 },
    ["renegade"] = { paid_chance = 20, free_chance = 10, refuse_chance = 70 },
    ["greh"]     = { paid_chance = 10, free_chance = 10, refuse_chance = 80 },
    ["isg"]      = { paid_chance = 30, free_chance = 40, refuse_chance = 30 },
    ["monolith"] = { paid_chance = 00, free_chance = 80, refuse_chance = 20 },

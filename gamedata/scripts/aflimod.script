    ["l11_pripyat"] = { "monolith", "stalker", "isg", "greh", "army" },
    ["pripyat"] = { "monolith", "killer", "isg", "stalker", "greh" },
    ["zaton"] = { "stalker", "killer", "bandit", "renegade", "monolith" },
    ["l12_stancia"] = { "monolith", "stalker", "isg", "greh" },

local rank_behaviors = {
    ["novice"]          = {order = 1, accuracy = 30, cap = 1, min_conf = 30, max_conf = 80},
    ["trainee"]         = {order = 2, accuracy = 40, cap = 1, min_conf = 40, max_conf = 80},
    ["experienced"]     = {order = 3, accuracy = 50, cap = 2, min_conf = 60, max_conf = 80},
    ["professional"]    = {order = 4, accuracy = 60, cap = 2, min_conf = 70, max_conf = 90},
    ["veteran"]         = {order = 5, accuracy = 70, cap = 3, min_conf = 80, max_conf = 90},
    ["expert"]          = {order = 6, accuracy = 80, cap = 3, min_conf = 90, max_conf = 100},
    ["master"]          = {order = 7, accuracy = 90, cap = 4, min_conf = 100, max_conf = 100},
    ["legend"]          = {order = 8, accuracy = 99, cap = 5, min_conf = 100, max_conf = 100},
}

local level_plausible_factions = { -- USED FOR NPCS MISTAKES
    ["l01_escape"] = { "stalker", "army", "bandit", "renegade" },
    ["k00_marsh"] = { "stalker", "csky", "bandit", "renegade" },
    ["l02_garbage"] = { "stalker", "bandit", "renegade", "dolg" },
    ["y04_pole"] = { "stalker", "bandit", "army", "renegade" },
    ["k01_darkscape"] = { "stalker", "bandit", "army", "monolith", "renegade" },
    ["l03_agroprom"] = { "stalker", "army", "bandit", "dolg", "renegade" },
    ["l04_darkvalley"] = { "stalker", "bandit", "freedom", "renegade" },
    ["l08_yantar"] = { "stalker", "army", "ecolog", "monolith", "renegade" },
    ["l06_rostok"] = { "stalker", "killer", "renegade", "bandit" },
    ["l05_bar"] = { "stalker", "dolg", "killer", "bandit" },
    ["k02_trucks_cemetery"] = { "stalker", "bandit", "freedom", "army", "renegade" },
    ["l09_deadcity"] = { "killer", "bandit", "stalker", "isg", "renegade" },
    ["l07_military"] = { "stalker", "army", "freedom", "dolg", "killer" },
    ["l10_red_forest"] = { "stalker", "monolith", "army", "freedom", "greh" },
    ["l10_radar"] = { "stalker", "monolith", "army", "greh" },
    ["l10_limansk"] = { "stalker", "monolith", "csky", "army", "greh" },
